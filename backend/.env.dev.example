# ==========================================
# PLANTILLA DE VARIABLES DE ENTORNO
# ==========================================
# INSTRUCCIONES: Copia este archivo, renómbralo a '.env' 
# y rellena los valores con tus credenciales locales.
# NO subas el archivo '.env' real a GitHub.

# --- Configuración principal de Django ---
DEBUG=True
DJANGO_SECRET_KEY=poner_aqui_clave_secreta
# --- Base de Datos (PostgreSQL) ---
POSTGRES_DB=current_DB
POSTGRES_USER=current_User
POSTGRES_PASSWORD=poner_aqui_contraseña
# Usa '127.0.0.1' si corres la BBDD en tu máquina, o 'db' si usas Docker Compose
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Caché y WebSockets (Redis) ---
# Usa '127.0.0.1' en local, o 'redis' si usas Docker Compose
REDIS_HOST=redis
REDIS_PORT=6379

# --- Almacenamiento en la Nube (AWS S3) ---
# Nota: En desarrollo local (cuando DEBUG=True) Django ignora esto y usa la carpeta /media/
AWS_ACCESS_KEY_ID=dejar_vacio_en_local
AWS_SECRET_ACCESS_KEY=dejar_vacio_en_local
AWS_STORAGE_BUCKET_NAME=dejar_vacio_en_local
AWS_S3_ENDPOINT_URL=dejar_vacio_en_local

# --- Compartir calendarios (Open Graph preview) ---
# Opcional: URL pública de imagen para og:image (sobreescribe el logo por defecto en /static/images/og-default.png)
# Dejar vacío para usar la imagen estática automáticamente.
SHARE_OG_IMAGE_FALLBACK=

GOOGLE_REDIRECT_URIS=http://localhost:8000/oauth2callback/
FRONTEND_URL=http://localhost:8081
GOOGLE_CLIENT_ID = 'tu-client-id-de-google'
GOOGLE_CLIENT_SECRET= 'tu-client-secret-de-google'
GOOGLE_PROJECT_ID = 'tu-project-id-de-google'